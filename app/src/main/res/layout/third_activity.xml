<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#9C27B0"
        android:padding="16dp"
        android:text="Calculator"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:elevation="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="bottom|end"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_expression"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="24sp"
            android:textColor="#757575" />

        <TextView
            android:id="@+id/tv_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="64sp"
            android:textColor="#212121"
            android:textStyle="bold" />
    </LinearLayout>

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="*"
        android:padding="8dp">


        <TableRow android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn_clear" android:text="AC" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="#FF5252" android:textSize="20sp" />
            <Button android:id="@+id/btn_percent" android:text="%" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="20sp" />
            <Button android:id="@+id/btn_backspace" android:text="⌫" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="20sp" />
            <Button android:id="@+id/btn_divide" android:text="÷" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#9C27B0" />
        </TableRow>


        <TableRow android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn_7" android:text="7" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#424242" />
            <Button android:id="@+id/btn_8" android:text="8" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#424242" />
            <Button android:id="@+id/btn_9" android:text="9" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#424242" />
            <Button android:id="@+id/btn_multiply" android:text="×" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#9C27B0" />
        </TableRow>


        <TableRow android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn_4" android:text="4" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#424242" />
            <Button android:id="@+id/btn_5" android:text="5" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#424242" />
            <Button android:id="@+id/btn_6" android:text="6" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#424242" />
            <Button android:id="@+id/btn_subtract" android:text="−" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#9C27B0" />
        </TableRow>


        <TableRow android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn_1" android:text="1" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#424242" />
            <Button android:id="@+id/btn_2" android:text="2" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#424242" />
            <Button android:id="@+id/btn_3" android:text="3" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#424242" />
            <Button android:id="@+id/btn_add" android:text="+" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#9C27B0" />
        </TableRow>


        <TableRow>
            <Button android:id="@+id/btn_0" android:text="0" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#424242" />
            <Button android:id="@+id/btn_dot" android:text="." style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp" android:textColor="#424242" />
            <Button android:id="@+id/btn_equal" android:text="=" android:layout_span="2" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:backgroundTint="#9C27B0" android:textColor="#FFFFFF" android:textSize="24sp" />
        </TableRow>

    </TableLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:elevation="8dp">

        <Button
            android:id="@+id/nav_to_lcm"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LCM" />

        <Button
            android:id="@+id/nav_to_power"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Power" />
    </LinearLayout>

</LinearLayout>
